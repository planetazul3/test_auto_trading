# Copy this file to .env and fill in your values.
# .env is .gitignored — no se versiona.

# -- Deriv WebSocket API ---------------------------------------------------
# Registrá tu app en https://app.deriv.com/account/api-token
DERIV_APP_ID=
DERIV_API_TOKEN=
# Endpoint alternativo (testnet, regional). Default: wss://ws.derivws.com/websockets/v3
# DERIV_ENDPOINT=wss://ws.derivws.com/websockets/v3

# -- Observabilidad --------------------------------------------------------
# Nivel de logging global (DEBUG/INFO/WARNING/ERROR). Default INFO.
LOG_LEVEL=INFO
# Puerto para el HTTP exporter de Prometheus (sólo si llamás
# src.observability.metrics.start_http_server).
# PROMETHEUS_PORT=9090

# -- Training / Optuna -----------------------------------------------------
# Override del seed para reproducibilidad cross-machine.
# PYTHONHASHSEED=0
